# FlixNest Environment Variables
# Copy this file to .env.local and update values

# ============================================================
# BACKEND SCRAPER (PRIMARY - Required for NativePlayer)
# ============================================================

# URL of the Playwright-based scraper service
# Development: http://localhost:3001/api/extract
# Production: https://your-railway-app.railway.app/api/extract
#             or https://your-render-app.onrender.com/api/extract
VITE_SCRAPER_URL=http://localhost:3001/api/extract

# ============================================================
# PROXY WORKER (FALLBACK - for same-origin proxy attempt)
# ============================================================

# URL of deployed Cloudflare Worker proxy
# Development: http://localhost:8787
# Production: https://flixnest-proxy.YOUR_SUBDOMAIN.workers.dev
VITE_PROXY_WORKER_URL=http://localhost:8787

# ============================================================
# OPTIONAL: External Extraction Service (Legacy fallback)
# ============================================================

# URL of Playwright-based extraction service (if deployed)
# VITE_EXTRACTOR_SERVICE_URL=https://your-extractor-service.workers.dev/extract
